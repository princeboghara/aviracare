<!DOCTYPE html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Admin Dashboard - Avira Control Center</title>
    <!-- Tailwind CSS & FontAwesome -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* 🌌 OVERFLOW SAFE GLASS EFFECTS */
        html, body {
            max-width: 100vw !important;
            overflow-x: hidden !important;
            position: relative;
        }

        /* ✨ 3D & Advanced Animation Effects */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-fade-down { animation: fadeInDown 1s cubic-bezier(0.19, 1, 0.22, 1) forwards; }
        .animate-fade-up { animation: fadeInUp 1.2s cubic-bezier(0.19, 1, 0.22, 1) forwards; }

        /* Neon & Glass Overlays */
        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        /* 🌌 Premium 3D Interactive Cards */
        .premium-3d-card {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 250, 252, 0.8) 100%);
            transform-style: preserve-3d;
            perspective: 1000px;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        .premium-3d-card:hover {
            transform: translateY(-8px) scale(1.02) rotateX(2deg);
            background: white;
            border-color: rgba(16, 185, 129, 0.4);
        }

        /* Neon Shadow Glows */
        .glow-blue:hover { box-shadow: 0 30px 60px -15px rgba(59, 130, 246, 0.25), 0 0 50px rgba(59, 130, 246, 0.1); }
        .glow-emerald:hover { box-shadow: 0 30px 60px -15px rgba(16, 185, 129, 0.25), 0 0 50px rgba(16, 185, 129, 0.1); }
        .glow-amber:hover { box-shadow: 0 30px 60px -15px rgba(245, 158, 11, 0.25), 0 0 50px rgba(245, 158, 11, 0.1); }
        .glow-purple:hover { box-shadow: 0 30px 60px -15px rgba(168, 85, 247, 0.25), 0 0 50px rgba(168, 85, 247, 0.1); }

        /* Inside Elements Push out 3D */
        .inner-3d { transform: translateZ(20px); }
    </style>
</head>
<body class="bg-gradient-to-br from-slate-50 via-emerald-50/20 to-teal-50/40 min-h-screen flex flex-col justify-between font-sans antialiased text-slate-800 relative w-full overflow-x-hidden">

    <!-- STRICT BOUNDED BACKGROUND DECORATIVE ORBS -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute -top-10 -left-10 w-72 h-72 sm:w-96 sm:h-96 rounded-full bg-emerald-400/10 blur-[100px]"></div>
        <div class="absolute -bottom-10 -right-10 w-72 h-72 sm:w-96 sm:h-96 rounded-full bg-teal-400/10 blur-[100px]"></div>
    </div>

    <!-- Top Premium Header -->
    <header class="glass-panel sticky top-0 z-50 px-4 sm:px-8 py-3.5 flex justify-between items-center shadow-sm border-b border-slate-200/50 animate-fade-down w-full">
        <div class="flex items-center gap-2.5 sm:gap-3 min-w-0">
            <div class="h-9 w-9 sm:h-10 sm:w-10 rounded-xl overflow-hidden bg-white flex items-center justify-center shadow-md border border-slate-700/50 flex-shrink-0">
                <img src="/images/logo.jpg" alt="Avira Logo" class="h-full w-full object-cover">
            </div>
            <span class="text-base sm:text-xl font-black tracking-tight text-slate-900 truncate">Avira <span class="text-emerald-500 font-bold">Control Hub</span></span>
        </div>
        
        <div class="flex items-center gap-3 sm:gap-4 flex-shrink-0 ml-2">
            <div class="hidden sm:flex flex-col text-right">
                <p class="text-xs font-black text-slate-800">Master Root Admin</p>
                <span class="text-[9px] font-bold text-emerald-500 uppercase tracking-widest flex items-center justify-end gap-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 inline-block animate-ping"></span> Live Session
                </span>
            </div>
            <a href="/admin/logout" class="text-[10px] sm:text-xs font-bold uppercase tracking-wider bg-slate-900 text-white hover:bg-rose-600 px-3.5 py-2 sm:px-5 sm:py-2.5 rounded-xl transition-all shadow-md cursor-pointer flex items-center">
                <i class="fa-solid fa-arrow-right-from-bracket mr-1"></i> Exit Panel
            </a>
        </div>
    </header>

    <!-- Main Operational Dashboard -->
    <main class="flex-grow flex flex-col items-center justify-center max-w-6xl w-full mx-auto px-4 sm:px-6 py-8 sm:py-12 relative z-10 box-border">
        
        <!-- Welcome Hero Text Section -->
        <div class="text-center max-w-2xl mb-8 sm:mb-14 space-y-3 sm:space-y-4 animate-fade-down">
            <span class="bg-gradient-to-r from-emerald-500/10 to-teal-500/10 border border-emerald-500/20 text-emerald-700 text-[9px] sm:text-[10px] font-black px-3.5 py-1 sm:px-4 sm:py-1.5 rounded-full uppercase tracking-widest shadow-sm inline-block">
                ⚡ Secure Admin Console Workspace ⚡
            </span>
            <h1 class="text-2xl sm:text-4xl md:text-5xl font-black tracking-tight text-slate-950 leading-tight">
                Welcome Back, Chief Administrator
            </h1>
            <p class="text-slate-500 text-xs sm:text-sm max-w-lg mx-auto leading-relaxed font-medium">
                Avira Care system architecture centralized dashboard. Direct link shortcuts control panels optimized for fast execution.
            </p>
        </div>

        <!-- 3D Grid Operational Workspace -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 w-full animate-fade-up">
            
            <!-- MODULE 1: CONTENT MANAGER -->
            <a href="/admin/content-manager"
                class="premium-3d-card glow-blue p-5 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col justify-between group cursor-pointer shadow-xl relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-blue-500/[0.02] to-transparent pointer-events-none"></div>
                <div class="text-center mb-5 sm:mb-6 inner-3d">
                    <div class="w-12 h-12 sm:w-14 sm:h-14 bg-blue-50 text-blue-500 group-hover:bg-blue-500 group-hover:text-white rounded-2xl flex items-center justify-center text-lg sm:text-xl mx-auto mb-4 sm:mb-5 border border-blue-100 transition-all shadow-md shadow-blue-500/5 duration-500">
                        <i class="fa-solid fa-file-pdf"></i>
                    </div>
                    <h3 class="text-sm sm:text-base font-black text-slate-900 mb-1.5 sm:mb-2 group-hover:text-blue-600 transition-colors duration-300">1. Content Manager</h3>
                    <p class="text-slate-400 text-[10px] sm:text-[11px] leading-relaxed font-medium">Upload, manage, and replace PDF flyers or assets for the MLM Business Plan and Product Catalog instantly.</p>
                </div>
                <div class="pt-3.5 border-t border-slate-100 flex items-center justify-center text-[10px] sm:text-[11px] font-bold text-blue-500 group-hover:gap-2 transition-all duration-300 inner-3d">
                    <span>Open Workspace</span> <i class="fa-solid fa-arrow-right-long ml-1 group-hover:translate-x-1 transition-transform"></i>
                </div>
            </a>
            
            <!-- MODULE 2: TRACKING MANAGER -->
            <a href="/admin/tracking" 
               class="premium-3d-card glow-emerald p-5 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col justify-between group cursor-pointer shadow-xl relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/[0.02] to-transparent pointer-events-none"></div>
                <div class="text-center mb-5 sm:mb-6 inner-3d">
                    <div class="w-12 h-12 sm:w-14 sm:h-14 bg-emerald-50 text-emerald-500 group-hover:bg-emerald-500 group-hover:text-white rounded-2xl flex items-center justify-center text-lg sm:text-xl mx-auto mb-4 sm:mb-5 border border-emerald-100 transition-all shadow-md shadow-emerald-500/5 duration-500">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                    <h3 class="text-sm sm:text-base font-black text-slate-900 mb-1.5 sm:mb-2 group-hover:text-emerald-600 transition-colors duration-300">2. Tracking Manager</h3>
                    <p class="text-slate-400 text-[10px] sm:text-[11px] leading-relaxed font-medium">Core logistics console. Upload bulk files, initiate manual shipping data pipelines, or fetch permanent excel rows.</p>
                </div>
                <div class="pt-3.5 border-t border-slate-100 flex items-center justify-center text-[10px] sm:text-[11px] font-bold text-emerald-500 group-hover:gap-2 transition-all duration-300 inner-3d">
                    <span>Launch Logistics Panel</span> <i class="fa-solid fa-arrow-right-long ml-1 group-hover:translate-x-1 transition-transform"></i>
                </div>
            </a>

            <!-- MODULE 3: QUERY MANAGER -->
            <a href="/admin/queries"
                 class="premium-3d-card glow-amber p-5 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col justify-between group cursor-pointer shadow-xl relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-amber-500/[0.02] to-transparent pointer-events-none"></div>
                <div class="text-center mb-5 sm:mb-6 inner-3d">
                    <div class="w-12 h-12 sm:w-14 sm:h-14 bg-amber-50 text-amber-500 group-hover:bg-amber-500 group-hover:text-white rounded-2xl flex items-center justify-center text-lg sm:text-xl mx-auto mb-4 sm:mb-5 border border-amber-100 transition-all shadow-md shadow-amber-500/5 duration-500">
                        <i class="fa-solid fa-headset"></i>
                    </div>
                    <h3 class="text-sm sm:text-base font-black text-slate-900 mb-1.5 sm:mb-2 group-hover:text-amber-600 transition-colors duration-300">3. Query Manager</h3>
                    <p class="text-slate-400 text-[10px] sm:text-[11px] leading-relaxed font-medium">Review customer tickets, technical queries, or address change requests triggered dynamically by active members.</p>
                </div>
                <div class="pt-3.5 border-t border-slate-100 flex items-center justify-center text-[10px] sm:text-[11px] font-bold text-amber-500 group-hover:gap-2 transition-all duration-300 inner-3d">
                    <span>Open Ticket Console</span> <i class="fa-solid fa-arrow-right-long ml-1 group-hover:translate-x-1 transition-transform"></i>
                </div>
            </a>

            <!-- MODULE 4: PRODUCT SHOWCASE MANAGER -->
            <a href="/admin/add-product"
                 class="premium-3d-card glow-purple p-5 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col justify-between group cursor-pointer shadow-xl relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-purple-500/[0.02] to-transparent pointer-events-none"></div>
                <div class="text-center mb-5 sm:mb-6 inner-3d">
                    <div class="w-12 h-12 sm:w-14 sm:h-14 bg-purple-50 text-purple-500 group-hover:bg-purple-500 group-hover:text-white rounded-2xl flex items-center justify-center text-lg sm:text-xl mx-auto mb-4 sm:mb-5 border border-purple-100 transition-all shadow-md shadow-purple-500/5 duration-500">
                        <i class="fa-solid fa-basket-shopping"></i>
                    </div>
                    <h3 class="text-sm sm:text-base font-black text-slate-900 mb-1.5 sm:mb-2 group-hover:text-purple-600 transition-colors duration-300">4. Product Manager</h3>
                    <p class="text-slate-400 text-[10px] sm:text-[11px] leading-relaxed font-medium">Publish new inventory dynamically. Upload item image assets, set point value (PV) bounds, amounts, and metadata bounds.</p>
                </div>
                <div class="pt-3.5 border-t border-slate-100 flex items-center justify-center text-[10px] sm:text-[11px] font-bold text-purple-500 group-hover:gap-2 transition-all duration-300 inner-3d">
                    <span>Add New Product</span> <i class="fa-solid fa-arrow-right-long ml-1 group-hover:translate-x-1 transition-transform"></i>
                </div>
            </a>

        </div>
    </main>
    
    <!-- Secure Footer -->
    <footer class="glass-panel border-t border-slate-200/40 py-4 text-center text-[10px] sm:text-[11px] font-semibold text-slate-400 shadow-inner w-full overflow-hidden">
        &copy; 2026 Avira Control Center. Encrypted TLS 1.3 Administrator System.
    </footer>

</body>
</html>

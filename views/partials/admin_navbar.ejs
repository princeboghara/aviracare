<!-- Overlay Back Drop Mask for Mobile Sidebar Controls View toggle -->
<div id="sidebarOverlay" onclick="toggleMobileSidebar()" class="hidden fixed inset-0 bg-slate-950/20 backdrop-blur-sm z-40 lg:hidden"></div>

<!-- Core Sidebar Engine Controller Script Grid Node -->
<script>
    function toggleSidebarAccordion(element) {
        const currentItem = element.closest('.nav-accordion-item');
        const isOpen = currentItem.classList.contains('nav-item-open');
        
        document.querySelectorAll('.nav-accordion-item').forEach(item => {
            if(item !== currentItem) {
                item.classList.remove('nav-item-open');
            }
        });
        
        currentItem.classList.toggle('nav-item-open');
    }

    function toggleMobileSidebar() {
        const sidebar = document.getElementById('adminSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        if(sidebar.classList.contains('-translate-x-full')) {
            sidebar.classList.remove('-translate-x-full');
            overlay.classList.remove('hidden');
        } else {
            sidebar.classList.add('-translate-x-full');
            overlay.classList.add('hidden');
        }
    }

    // 🎯 એક્ટિવ યુઆરએલ પ્રમાણે સબ-મેનુ ઓટોમેટીક ઓપન રાખવાનો જુગાડ
    document.addEventListener("DOMContentLoaded", function() {
        const currentPath = window.location.pathname;
        const subLinks = document.querySelectorAll(".nav-sub-content a");
        
        subLinks.forEach(link => {
            if(link.getAttribute("href") === currentPath) {
                link.classList.remove("text-slate-500");
                link.classList.add("text-emerald-600", "font-black");
                link.innerHTML = link.innerHTML.replace("↳", "⚡");
                
                const parentAccordion = link.closest(".nav-accordion-item");
                if(parentAccordion) {
                    parentAccordion.classList.add("nav-item-open");
                }
            }
        });

        const mainLinks = document.querySelectorAll("nav > a");
        mainLinks.forEach(link => {
            if(link.getAttribute("href") === currentPath) {
                link.classList.add("text-emerald-600", "bg-emerald-500/10", "border-emerald-500/20");
            }
        });
    });
</script>
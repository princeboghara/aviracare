<style>
    /* 🌌 Ultra Premium Light 3D Glass Engine */
    .cyber-sidebar {
        background: rgba(255, 255, 255, 0.85) !important;
        backdrop-filter: blur(25px) saturate(180%);
        -webkit-backdrop-filter: blur(25px) saturate(180%);
        border-right: 1px solid rgba(255, 255, 255, 0.6);
        box-shadow: 10px 0 40px -15px rgba(15, 23, 42, 0.08);
        transform-style: preserve-3d;
        perspective: 1000px;
    }

    /* ✨ Smooth Hydraulic Accordion Transition */
    .nav-sub-content {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transform: translateY(-6px) scale(0.98);
        transition: max-height 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                    opacity 0.3s ease-out, 
                    transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .nav-item-open .nav-sub-content {
        max-height: 250px;
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    /* 🚀 3D Animated Interactive Anchors */
    .cyber-link {
        position: relative;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid transparent;
        color: #475569;
    }
    .cyber-link:hover {
        transform: translateZ(15px) translateX(5px);
        background: rgba(16, 185, 129, 0.08) !important;
        border-color: rgba(16, 185, 129, 0.2);
        color: #059669 !important;
    }
    .cyber-link:hover i {
        color: #10b981 !important;
        transform: scale(1.1);
    }

    /* 🟢 Active 3D State Badge */
    .nav-item-open > .cyber-link {
        background: rgba(16, 185, 129, 0.06) !important;
        border-color: rgba(16, 185, 129, 0.15);
        color: #059669 !important;
    }
    .nav-item-open .nav-chevron {
        transform: rotate(180deg);
        color: #10b981;
    }

    /* ❌ Exit/Logout Premium Button */
    .cyber-exit {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #64748b;
        transition: all 0.3s ease;
    }
    .cyber-exit:hover {
        background: linear-gradient(135deg, #f43f5e, #e11d48);
        border-color: #f43f5e;
        color: white !important;
        box-shadow: 0 10px 20px -5px rgba(244, 63, 94, 0.3);
        transform: translateY(-2px);
    }

    /* Custom Scrollbar */
    .cyber-scroll::-webkit-scrollbar { width: 4px; }
    .cyber-scroll::-webkit-scrollbar-track { background: transparent; }
    .cyber-scroll::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.05); border-radius: 10px; }
</style>


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Login - Avira Control</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-slate-900 flex items-center justify-center min-h-screen">
    <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-sm text-center">
        <h2 class="text-xl font-black uppercase mb-6 text-slate-900">Admin Login</h2>
        <form action="/admin/login" method="POST" class="space-y-4">
            <input type="text" name="username" placeholder="Username" required class="w-full p-3 bg-slate-50 border rounded-xl text-xs font-bold">
            <input type="password" name="password" placeholder="Password" required class="w-full p-3 bg-slate-50 border rounded-xl text-xs font-bold">
            <button type="submit" class="w-full bg-emerald-500 text-white font-black py-3 rounded-xl uppercase hover:bg-emerald-600 transition-all">Sign In</button>
        </form>
    </div>
</body>
</html>
<!DOCTYPE html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Welcome to Avira Lifecare</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link class="fallback" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* 🌌 OVERFLOW SAFE GLASS EFFECTS */
        html, body {
            max-width: 100vw !important;
            overflow-x: hidden !important;
            position: relative;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 20px 40px -15px rgba(15, 23, 42, 0.05);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .glass-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 30px 60px -15px rgba(16, 185, 129, 0.15);
            background: rgba(255, 255, 255, 0.9);
        }

        /* ✨ STRICT OVERFLOW BOUNDED ANIMATED BLOBS */
        .animated-blob {
            filter: blur(80px);
            opacity: 0.35;
            animation: floatBlob 16s infinite alternate ease-in-out;
            will-change: transform;
        }
        @keyframes floatBlob {
            0% { transform: translate(0px, 0px) scale(1); }
            50% { transform: translate(20px, -10px) scale(1.05); }
            100% { transform: translate(-10px, 20px) scale(0.95); }
        }

        /* 🚀 PULSE RING ANIMATION */
        .pulse-effect {
            position: relative;
        }
        .pulse-effect::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.5);
            animation: pulseAnim 2s infinite;
        }
        @keyframes pulseAnim {
            0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
            70% { box-shadow: 0 0 0 12px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }

        /* 💎 FOOTER LUXURY GLASS CARD */
        .footer-card {
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
        }
        .footer-card:hover {
            background: rgba(255, 255, 255, 0.95);
            transform: translateY(-4px);
            box-shadow: 0 12px 25px -5px rgba(16, 185, 129, 0.12);
            border-color: rgba(16, 185, 129, 0.3);
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col justify-between font-sans antialiased text-slate-800 relative w-full overflow-x-hidden">

    <!-- 🔮 STRICT BOUNDED BACKGROUND ANIMATED SHAPES -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute -top-20 -left-20 w-72 h-72 sm:w-96 sm:h-96 bg-emerald-400/20 rounded-full animated-blob"></div>
        <div class="absolute -bottom-20 -right-20 w-72 h-72 sm:w-96 sm:h-96 bg-blue-400/20 rounded-full animated-blob" style="animation-delay: -6s;"></div>
    </div>

    <!-- 🌐 MAIN NAVIGATION HEADER WITH SUPPORT BUTTON -->
    <header class="bg-white/70 backdrop-blur-md border-b border-slate-100 px-4 sm:px-8 py-3.5 sticky top-0 z-50 shadow-sm w-full">
        <div class="max-w-4xl mx-auto flex justify-between items-center w-full">
            
            <!-- Left: Brand Info -->
            <div class="flex items-center gap-2.5 sm:gap-3 min-w-0">
                <div class="h-9 w-9 sm:h-10 sm:w-10 rounded-xl overflow-hidden bg-white flex items-center justify-center shadow-md border border-slate-100 flex-shrink-0">
                    <img src="/images/logo.jpg" alt="Avira Logo" class="h-full w-full object-cover">
                </div>
                <div class="truncate">
                    <span class="text-xs sm:text-base font-black tracking-tight text-slate-900 uppercase block truncate">AVIRA LIFECARE GLOBAL PRIVATE LIMITED</span>
                    <span class="text-[8px] sm:text-[9px] font-bold text-emerald-600 uppercase tracking-widest block -mt-0.5">Official Member Portal</span>
                </div>
            </div>

            <!-- Right: 🎧 Support Scroll Button -->
            <a href="#footer" class="group flex items-center gap-1.5 bg-white/90 hover:bg-emerald-50 border border-slate-200 hover:border-emerald-300 text-slate-700 hover:text-emerald-700 px-3 py-1.5 sm:px-3.5 sm:py-2 rounded-xl transition-all shadow-xs cursor-pointer font-bold text-[11px] sm:text-xs uppercase tracking-wider flex-shrink-0 ml-2">
                <i class="fa-solid fa-headset text-emerald-500 group-hover:scale-110 transition-transform"></i>
                <span class="hidden sm:inline">Support</span>
            </a>

        </div>
    </header>

    <!-- 📦 MAIN HERO & BUTTONS WORKSPACE -->
    <main class="flex-grow w-full max-w-4xl mx-auto px-4 py-6 sm:py-12 flex flex-col justify-center gap-6 sm:gap-10 relative z-10 box-border">
        
        <!-- Welcome Hero Info -->
        <div class="w-full text-center space-y-3 max-w-2xl mx-auto">
            <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black bg-emerald-50 text-emerald-700 border border-emerald-100 uppercase tracking-wider shadow-sm">
                <i class="fa-solid fa-circle-check"></i> Connected Workspace
            </div>
            <h1 class="text-2xl sm:text-5xl font-black tracking-tight text-slate-950 leading-tight">
                Empowering Health,<br class="hidden sm:inline"> Enriching Life.
            </h1>
            <p class="text-slate-500 text-xs sm:text-sm leading-relaxed max-w-xl mx-auto">
                Welcome to your Avira Dashboard. Access official marketing documents, download digital catalogs, manage your queries, and monitor your package deliveries in real-time.
            </p>
        </div>

        <!-- 🚀 3D ANIMATED ACTION CARDS -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-6 max-w-4xl mx-auto w-full">
            
            <!-- ✅ CARD 1: BUSINESS PLAN -->
            <div class="glass-card p-3.5 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col justify-between text-center sm:text-left relative overflow-hidden group">
                <div class="mb-3 sm:mb-6">
                    <div class="w-9 h-9 sm:w-12 sm:h-12 bg-emerald-50 text-emerald-500 rounded-xl sm:rounded-2xl flex items-center justify-center text-base sm:text-xl mx-auto sm:mx-0 mb-2 sm:mb-4 border border-emerald-100/50">
                        <i class="fa-solid fa-chart-pie"></i>
                    </div>
                    <h3 class="text-xs sm:text-base font-black text-slate-900 mb-1">Business Plan</h3>
                    <p class="text-slate-400 text-[9px] sm:text-xs leading-tight sm:leading-relaxed line-clamp-2">Download compensation plan flyers.</p>
                </div>

                <a href="<%= businessPlan %>" download class="w-full text-center bg-slate-900 hover:bg-slate-950 text-white font-bold text-[10px] sm:text-xs py-2 sm:py-3 rounded-lg sm:rounded-xl transition-all shadow-md uppercase tracking-wider flex items-center justify-center gap-1 sm:gap-2 cursor-pointer">
                    Plan <i class="fa-solid fa-file-arrow-download text-[10px]"></i>
                </a>
            </div>

            <!-- ✅ CARD 2: PRODUCT CATALOG -->
            <div class="glass-card p-3.5 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col justify-between text-center sm:text-left relative overflow-hidden group">
                <div class="mb-3 sm:mb-6">
                    <div class="w-9 h-9 sm:w-12 sm:h-12 bg-blue-50 text-blue-500 rounded-xl sm:rounded-2xl flex items-center justify-center text-base sm:text-xl mx-auto sm:mx-0 mb-2 sm:mb-4 border border-blue-100/50">
                        <i class="fa-solid fa-book-open"></i>
                    </div>
                    <h3 class="text-xs sm:text-base font-black text-slate-900 mb-1">Catalog PDF</h3>
                    <p class="text-slate-400 text-[9px] sm:text-xs leading-tight sm:leading-relaxed line-clamp-2">Download active wellness catalog files.</p>
                </div>

                <a href="<%= catalog %>" download class="w-full text-center bg-slate-900 hover:bg-slate-950 text-white font-bold text-[10px] sm:text-xs py-2 sm:py-3 rounded-lg sm:rounded-xl transition-all shadow-md uppercase tracking-wider flex items-center justify-center gap-1 sm:gap-2 cursor-pointer">
                    Catalog <i class="fa-solid fa-file-arrow-download text-[10px]"></i>
                </a>
            </div>

            <!-- 🔥 CARD 3: ABOUT OUR PRODUCTS -->
            <div class="glass-card p-3.5 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col justify-between text-center sm:text-left relative overflow-hidden group border-emerald-200 col-span-2 md:col-span-1">
                <div class="mb-3 sm:mb-6">
                    <div class="w-9 h-9 sm:w-12 sm:h-12 bg-teal-50 text-teal-600 rounded-xl sm:rounded-2xl flex items-center justify-center text-base sm:text-xl mx-auto sm:mx-0 mb-2 sm:mb-4 border border-teal-100/50">
                        <i class="fa-solid fa-basket-shopping"></i>
                    </div>
                    <h3 class="text-xs sm:text-base font-black text-slate-900 mb-1">About Our Products</h3>
                    <p class="text-slate-400 text-[9px] sm:text-xs leading-tight sm:leading-relaxed">Explore full digital store display pricing details and metrics.</p>
                </div>

                <a href="/products" class="w-full text-center bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-black text-[10px] sm:text-xs py-2 sm:py-3 rounded-lg sm:rounded-xl transition-all shadow-md uppercase tracking-wider flex items-center justify-center gap-1 sm:gap-2 cursor-pointer">
                    View Showcase <i class="fa-solid fa-magnifying-glass text-[9px]"></i>
                </a>
            </div>

        </div>

        <!-- 🔥 SHORTCUT BANNER ROW 1: LIVE TRACKING PORTAL -->
        <div class="w-full max-w-3xl mx-auto">
            <div class="glass-card p-4 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col sm:flex-row justify-between items-center gap-3 sm:gap-4 text-center sm:text-left border-emerald-200/40 relative overflow-hidden">
                <div class="flex flex-col sm:flex-row items-center gap-2.5 sm:gap-4">
                    <div class="w-10 h-10 sm:w-12 sm:h-12 bg-emerald-500 text-white rounded-2xl flex items-center justify-center text-base sm:text-lg shadow-md shadow-emerald-500/20 flex-shrink-0">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                    <div>
                        <h4 class="text-xs sm:text-sm font-black text-slate-900 uppercase tracking-wide">Looking for your product dispatch?</h4>
                        <p class="text-slate-400 text-[10px] sm:text-[11px] font-semibold mt-0.5">Track your India Post parcel live status instantly without logging in.</p>
                    </div>
                </div>
                <a href="/track-parcel" class="pulse-effect w-full sm:w-auto bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white font-black text-[11px] sm:text-xs py-2.5 sm:py-3 px-5 sm:px-6 rounded-xl transition-all shadow-md uppercase tracking-wider cursor-pointer text-center">
                    Live Tracking Portal &rarr;
                </a>
            </div>
        </div>

        <!-- 3D QUERY MANAGER MODULE CARD -->
        <div class="w-full max-w-3xl mx-auto">
            <div class="glass-card p-4 sm:p-6 rounded-2xl sm:rounded-3xl flex flex-col sm:flex-row justify-between items-center gap-3 sm:gap-4 text-center sm:text-left border-amber-200/40 relative overflow-hidden">
                <div class="flex flex-col sm:flex-row items-center gap-2.5 sm:gap-4">
                    <div class="w-10 h-10 sm:w-12 sm:h-12 bg-amber-500 text-slate-950 rounded-2xl flex items-center justify-center text-base sm:text-lg shadow-md shadow-amber-500/20 flex-shrink-0">
                        <i class="fa-solid fa-headset"></i>
                    </div>
                    <div>
                        <h4 class="text-xs sm:text-sm font-black text-slate-900 uppercase tracking-wide">Avira Support & Query Manager</h4>
                        <p class="text-slate-400 text-[10px] sm:text-[11px] font-semibold mt-0.5">Have any questions, product issues or payout doubts? Raise a ticket instantly.</p>
                    </div>
                </div>
                <a href="/member/queries" class="w-full sm:w-auto text-center bg-amber-500 hover:bg-amber-600 text-slate-950 font-black text-[11px] sm:text-xs py-2.5 sm:py-3 px-5 sm:px-6 rounded-xl shadow-md uppercase tracking-wider cursor-pointer">
                    Open Query Center &rarr;
                </a>
            </div>
        </div>

    </main>

    <!-- 🌐 🎯 PREMIUM FOOTER -->
    <footer id="footer" class="bg-white/80 backdrop-blur-xl border-t border-slate-200/80 pt-10 pb-8 px-4 sm:px-8 mt-12 relative z-10 text-slate-600 w-full overflow-hidden">
        <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5 text-xs pb-8 border-b border-slate-200/60">
            
            <!-- 🏢 Address Card -->
            <div class="footer-card p-4 sm:p-5 rounded-2xl flex flex-col justify-between">
                <div>
                    <div class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center text-sm mb-2.5">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <p class="text-[10px] font-black uppercase text-slate-400 tracking-wider">Corporate Office</p>
                    <p class="font-bold text-slate-900 uppercase leading-relaxed mt-1 text-[11px]">
                        103, The Galleria Business Hub 2,<br>
                        Surat, Gujarat - 395010
                    </p>
                </div>
            </div>

            <!-- 📞 Support Card -->
            <div class="footer-card p-4 sm:p-5 rounded-2xl flex flex-col justify-between">
                <div>
                    <div class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center text-sm mb-2.5">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <p class="text-[10px] font-black uppercase text-slate-400 tracking-wider">Helpline Desk</p>
                    <p class="font-mono font-black text-slate-950 text-sm tracking-wide mt-1">+91 97123 26273</p>
                </div>
                <p class="text-[10px] text-emerald-600 font-bold uppercase mt-2 flex items-center gap-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Mon - Sat: 10 AM - 6 PM
                </p>
            </div>

            <!-- 🌐 Web Presence Card -->
            <div class="footer-card p-4 sm:p-5 rounded-2xl flex flex-col justify-between">
                <div>
                    <div class="w-8 h-8 rounded-lg bg-purple-50 text-purple-600 flex items-center justify-center text-sm mb-2.5">
                        <i class="fa-solid fa-globe"></i>
                    </div>
                    <p class="text-[10px] font-black uppercase text-slate-400 tracking-wider">Digital Network</p>
                    <a href="https://www.aviralifecare.com" target="_blank" class="font-mono font-black text-slate-900 hover:text-emerald-600 transition-colors block text-xs underline mt-1">www.aviralifecare.com</a>
                </div>
                <p class="text-[10px] text-slate-400 font-bold mt-2"><i class="fa-solid fa-envelope text-slate-400 mr-1"></i> info@aviralifecare.com</p>
            </div>

        </div>

        <!-- Bottom Copyright Row -->
        <div class="pt-6 text-center text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-wider">
            &copy; 2026 Avira Lifecare Global Private Limited. All rights reserved.
        </div>
    </footer>

</body>
</html>

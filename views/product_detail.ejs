<!DOCTYPE html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= product.name %> - Avira Ultra 3D Details</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* 🌌 OVERFLOW SAFE GLASS EFFECTS */
        html, body {
            max-width: 100vw !important;
            overflow-x: hidden !important;
            position: relative;
        }

        /* 🌌 Google Translate ક્લીનઅપ સેટિંગ્સ */
        .goog-te-banner-frame { display: none !important; }
        body { top: 0px !important; }
        .goog-te-gadget { font-size: 0px !important; display: none !important; }
        
        /* ✨ STRICT OVERFLOW BOUNDED ANIMATED ORBS */
        .animated-orb {
            filter: blur(80px);
            opacity: 0.3;
            animation: floatOrb 14s infinite alternate ease-in-out;
            will-change: transform;
        }
        @keyframes floatOrb {
            0% { transform: translate(0px, 0px) scale(1); }
            100% { transform: translate(20px, -10px) scale(1.05); }
        }

        /* 💎 ફ્યુચરિસ્ટિક 3D ગ્લાસ બોક્સ */
        .glass-box {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 20px 50px -15px rgba(15, 23, 42, 0.05);
        }

        /* 🛸 Premium 3D Interactive Hover */
        .interactive-3d {
            transform-style: preserve-3d;
            perspective: 1000px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .interactive-3d:hover {
            transform: translateY(-4px) rotateX(1deg);
            box-shadow: 0 25px 50px -12px rgba(16, 185, 129, 0.15);
            border-color: rgba(16, 185, 129, 0.3);
            background: white;
        }
        
        .inner-3d { transform: translateZ(30px); }

        /* ⚡ ULTRA SMOOTH HYDRAULIC ACCORDION (CSS GRID ENGINE) */
        .accordion-item {
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .accordion-wrapper {
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .accordion-content {
            overflow: hidden;
            opacity: 0;
            transform: translateY(-8px);
            transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* 🟢 OPEN STATE WITH NEON GLOW */
        .accordion-open {
            border-color: rgba(16, 185, 129, 0.4) !important;
            background: rgba(255, 255, 255, 0.95) !important;
            box-shadow: 0 10px 30px -10px rgba(16, 185, 129, 0.2);
        }
        .accordion-open .accordion-wrapper {
            grid-template-rows: 1fr;
        }
        .accordion-open .accordion-content {
            opacity: 1;
            transform: translateY(0);
        }
        .accordion-open .chevron-icon {
            transform: rotate(180deg);
            color: #10b981;
            filter: drop-shadow(0 0 5px rgba(16, 185, 129, 0.4));
        }
    </style>
</head>
<body class="bg-gradient-to-br from-slate-50 to-emerald-50/30 min-h-screen font-sans antialiased flex flex-col justify-between relative w-full overflow-x-hidden">

    <!-- 🔮 STRICT BOUNDED BACKGROUND ANIMATED ORBS -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute -top-10 -left-10 w-72 h-72 sm:w-96 sm:h-96 bg-emerald-300 rounded-full animated-orb"></div>
        <div class="absolute -bottom-10 -right-10 w-72 h-72 sm:w-96 sm:h-96 bg-blue-300 rounded-full animated-orb" style="animation-delay: -5s;"></div>
    </div>

    <div class="w-full box-border">
        <!-- Top Action Navigation Bar -->
        <div class="max-w-xl mx-auto p-4 flex justify-between items-center mt-2 relative z-10 w-full">
            <a href="/products" class="text-xs bg-white/80 backdrop-blur-md border border-slate-200 hover:bg-slate-100 font-bold py-2 px-3.5 sm:py-2.5 sm:px-4 rounded-xl transition-all shadow-sm uppercase tracking-wider flex items-center gap-1 flex-shrink-0">
                <i class="fa-solid fa-arrow-left text-[10px]"></i> Back
            </a>
            
            <!-- Smart Custom Language Dropdown Selector -->
            <div class="flex items-center gap-1.5 sm:gap-2 bg-white/80 backdrop-blur-md border border-slate-200 px-2.5 py-1.5 sm:px-3 sm:py-2 rounded-xl shadow-sm flex-shrink-0">
                <span class="text-[9px] sm:text-[10px] font-black uppercase text-slate-400 flex items-center"><i class="fa-solid fa-language text-xs text-slate-400 mr-1"></i> Lang:</span>
                <select id="langSelect" onchange="changeLanguage(this.value)" class="bg-transparent text-xs font-bold focus:outline-none cursor-pointer">
                    <option value="en">English</option>
                    <option value="gu">ગુજરાતી</option>
                    <option value="hi">हिन्दी</option>
                </select>
            </div>
        </div>

        <!-- Main Workspace Frame -->
        <main class="max-w-xl mx-auto px-4 mt-2 mb-12 space-y-4 sm:space-y-5 relative z-10 box-border">
            
            <!-- 📸 3D IMAGE PREVIEW MODULE -->
            <div class="glass-box interactive-3d rounded-2xl sm:rounded-3xl p-3.5 sm:p-4 border border-white">
                <div class="w-full aspect-square bg-slate-50/60 rounded-xl sm:rounded-2xl overflow-hidden flex items-center justify-center p-3 sm:p-4 relative border border-slate-100/40 shadow-inner inner-3d">
                    <!-- 🛠️ SAFE IMAGE DISPLAY LOGIC -->
                    <img id="mainDisplayImage" src="<%= product.image_url || '/images/logo.jpg' %>" alt="<%= product.name %>" class="object-contain w-full h-full transition-all duration-500">
                    
                    <!-- Floating Neon PV Badge -->
                    <span class="absolute top-3 right-3 sm:top-4 sm:right-4 bg-emerald-500 text-slate-950 font-black px-2.5 py-0.5 sm:px-3 sm:py-1 rounded-lg sm:rounded-xl text-[9px] sm:text-[10px] shadow-lg tracking-widest uppercase">
                        <%= product.pv %> PV
                    </span>
                </div>

                <!-- 🖼️ MULTIPLE PICS ACCUMULATOR INTERFACE WITH SAFE PARSING -->
                <% 
                    let imagesArray = [];
                    try {
                        if (product.all_images) {
                            if (typeof product.all_images === 'string') {
                                if (product.all_images.startsWith('[')) {
                                    imagesArray = JSON.parse(product.all_images);
                                } else {
                                    imagesArray = [product.all_images];
                                }
                            } else if (Array.isArray(product.all_images)) {
                                imagesArray = product.all_images;
                            }
                        }
                    } catch(e) {
                        imagesArray = [];
                    }

                    if (!imagesArray || imagesArray.length === 0) {
                        if (product.image_url) {
                            imagesArray = [product.image_url];
                        }
                    }
                    imagesArray = imagesArray.filter(Boolean);
                %>

                <% if (imagesArray.length > 1) { %>
                    <div class="flex gap-2 sm:gap-2.5 mt-3 sm:mt-4 overflow-x-auto pb-1.5 inner-3d">
                        <% imagesArray.forEach((imgUrl, idx) => { %>
                            <button onclick="updatePreview('<%= imgUrl %>', this)" class="thumb-preview-btn h-12 w-12 sm:h-14 sm:w-14 rounded-xl border bg-white overflow-hidden flex-shrink-0 p-1 focus:outline-none transition-all shadow-sm <%= idx === 0 ? 'border-emerald-500 ring-2 ring-emerald-500/20' : 'border-slate-200' %>">
                                <img src="<%= imgUrl %>" class="h-full w-full object-contain">
                            </button>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <!-- 📝 PRODUCT DETAILS META CARD -->
            <div class="glass-box interactive-3d rounded-2xl sm:rounded-3xl p-4 sm:p-5 border border-white space-y-3 sm:space-y-4">
                <h1 class="text-base sm:text-xl font-black text-slate-900 leading-snug inner-3d break-words"><%= product.name %></h1>
                
                <div class="flex items-center gap-2 inner-3d">
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Price Point</span>
                    <span class="text-lg sm:text-xl font-black text-slate-950 bg-slate-100/50 px-3.5 py-1 sm:px-4 sm:py-1.5 rounded-xl sm:rounded-2xl border border-slate-200/40">
                        ₹<%= parseFloat(product.amount || 0).toLocaleString('en-IN') %>
                    </span>
                </div>
            </div>

            <!-- ⚡ ULTRA 3D HYDRAULIC GLIDE ACCORDIONS -->
            <div class="space-y-3">
                
                <!-- ACCORDION 1: PRODUCT DESCRIPTION -->
                <div class="glass-box rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden accordion-item">
                    <button onclick="toggleAccordion(this)" class="w-full px-4 sm:px-5 py-3.5 sm:py-4 flex justify-between items-center font-black text-xs uppercase tracking-wider text-slate-700 hover:bg-white/50 transition-colors text-left focus:outline-none cursor-pointer">
                        <span class="flex items-center gap-2"><i class="fa-solid fa-align-left text-emerald-500 text-sm"></i> Product Description</span>
                        <i class="fa-solid fa-circle-chevron-down text-xs text-slate-400 transition-transform duration-300 chevron-icon flex-shrink-0 ml-1"></i>
                    </button>
                    <div class="accordion-wrapper">
                        <div class="accordion-content bg-white/40 text-xs sm:text-sm leading-relaxed text-slate-600 border-t border-slate-100/70 p-4 sm:p-5">
                            <p class="whitespace-pre-line font-medium tracking-wide break-words"><%= product.info || 'No description available.' %></p>
                        </div>
                    </div>
                </div>

                <!-- ACCORDION 2: CORE BENEFITS -->
                <div class="glass-box rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden accordion-item">
                    <button onclick="toggleAccordion(this)" class="w-full px-4 sm:px-5 py-3.5 sm:py-4 flex justify-between items-center font-black text-xs uppercase tracking-wider text-slate-700 hover:bg-white/50 transition-colors text-left focus:outline-none cursor-pointer">
                        <span class="flex items-center gap-2"><i class="fa-solid fa-shield-heart text-emerald-500 text-sm"></i> Core Benefits</span>
                        <i class="fa-solid fa-circle-chevron-down text-xs text-slate-400 transition-transform duration-300 chevron-icon flex-shrink-0 ml-1"></i>
                    </button>
                    <div class="accordion-wrapper">
                        <div class="accordion-content bg-emerald-50/10 text-xs sm:text-sm leading-relaxed text-slate-700 border-t border-slate-100/70 p-4 sm:p-5">
                            <p class="whitespace-pre-line font-medium tracking-wide break-words"><%= product.benefits || 'No benefits details available.' %></p>
                        </div>
                    </div>
                </div>

                <!-- ACCORDION 3: HOW TO USE -->
                <div class="glass-box rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden accordion-item">
                    <button onclick="toggleAccordion(this)" class="w-full px-4 sm:px-5 py-3.5 sm:py-4 flex justify-between items-center font-black text-xs uppercase tracking-wider text-slate-700 hover:bg-white/50 transition-colors text-left focus:outline-none cursor-pointer">
                        <span class="flex items-center gap-2"><i class="fa-solid fa-circle-play text-emerald-500 text-sm"></i> How To Use</span>
                        <i class="fa-solid fa-circle-chevron-down text-xs text-slate-400 transition-transform duration-300 chevron-icon flex-shrink-0 ml-1"></i>
                    </button>
                    <div class="accordion-wrapper">
                        <div class="accordion-content bg-white/40 text-xs sm:text-sm leading-relaxed text-slate-600 border-t border-slate-100/70 p-4 sm:p-5">
                            <p class="whitespace-pre-line font-medium tracking-wide break-words"><%= product.how_to_use || 'No usage instructions available.' %></p>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <!-- 🌐 PREMIUM LIGHT GLASS-MORPHISM FOOTER -->
    <footer class="w-full bg-white/60 backdrop-blur-md border-t border-slate-200 py-4 text-center text-[11px] sm:text-xs font-bold text-slate-400 mt-auto relative z-10 overflow-hidden">
        &copy; 2026 Avira Life Care. All rights reserved.
    </footer>

    <!-- Hidden Native Google Translate Frame Integration Node -->
    <div id="google_translate_element" style="display:none !important;"></div>
    
    <script type="text/javascript">
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                includedLanguages: 'gu,hi,en',
                autoDisplay: false
            }, 'google_translate_element');
        }
    </script>
    <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <!-- UI Core Automation Engine Logic Script -->
    <script>
        // 📸 ૧. મલ્ટિપલ પિક્સ સ્વેપ પ્રિવ્યુઅર
        function updatePreview(url, btnElement) {
            const img = document.getElementById('mainDisplayImage');
            img.style.opacity = '0';
            
            document.querySelectorAll('.thumb-preview-btn').forEach(btn => {
                btn.classList.remove('border-emerald-500', 'ring-2', 'ring-emerald-500/20');
                btn.classList.add('border-slate-200');
            });

            if(btnElement) {
                btnElement.classList.remove('border-slate-200');
                btnElement.classList.add('border-emerald-500', 'ring-2', 'ring-emerald-500/20');
            }

            setTimeout(() => {
                img.src = url;
                img.style.opacity = '1';
            }, 200);
        }

        // ⚡ ૨. અલ્ટ્રા સ્મૂધ હાઇડ્રોલિક એકોર્ડિયન કંટ્રોલર
        function toggleAccordion(element) {
            const currentItem = element.closest('.accordion-item');
            const isOpen = currentItem.classList.contains('accordion-open');
            
            document.querySelectorAll('.accordion-item').forEach(item => {
                item.classList.remove('accordion-open');
            });
            
            if (!isOpen) {
                currentItem.classList.add('accordion-open');
            }
        }

        // 🌐 ૩. ગુગલ ટ્રાન્સલેટર ચેન્જર
        function changeLanguage(langCode) {
            const googleSelect = document.querySelector('.goog-te-combo');
            if (googleSelect) {
                googleSelect.value = langCode;
                googleSelect.dispatchEvent(new Event('change'));
            }
        }
    </script>
</body>
</html>

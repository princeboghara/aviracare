<!DOCTYPE html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Our Products - Avira Lifecare</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* 🌌 OVERFLOW SAFE GLASS EFFECTS */
        html, body {
            max-width: 100vw !important;
            overflow-x: hidden !important;
            position: relative;
        }

        /* 🌌 સુપર સ્ટાઈલિશ મોર્ડન ગ્લાસ કાર્ડ */
        .premium-product-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(226, 232, 240, 0.7);
            box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.03);
            transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .premium-product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 35px -10px rgba(16, 185, 129, 0.12);
            border-color: rgba(16, 185, 129, 0.3);
            background: #ffffff;
        }
        
        /* ✨ STRICT OVERFLOW BOUNDED ANIMATED ORBS */
        .animated-orb {
            filter: blur(80px);
            opacity: 0.25;
            animation: floatOrb 12s infinite alternate ease-in-out;
            will-change: transform;
        }
        @keyframes floatOrb {
            0% { transform: translate(0px, 0px) scale(1); }
            100% { transform: translate(20px, 20px) scale(1.05); }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col justify-between font-sans antialiased relative w-full overflow-x-hidden">

    <!-- 🔮 STRICT BOUNDED BACKGROUND DECORATION -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute -top-10 -left-10 w-72 h-72 sm:w-96 sm:h-96 bg-emerald-300 rounded-full animated-orb"></div>
        <div class="absolute -bottom-10 -right-10 w-72 h-72 sm:w-96 sm:h-96 bg-blue-300 rounded-full animated-orb" style="animation-delay: -4s;"></div>
    </div>

    <!-- 🌐 STYLISH STICKY HEADER -->
    <header class="bg-white/70 backdrop-blur-md border-b border-slate-200/50 px-4 sm:px-8 py-3.5 sticky top-0 z-50 shadow-sm flex justify-between items-center w-full">
        <div class="flex items-center gap-2.5 min-w-0">
            <div class="h-8 w-8 rounded-lg overflow-hidden bg-white flex items-center justify-center shadow-sm border border-slate-100 flex-shrink-0">
                <img src="/images/logo.jpg" alt="Avira Logo" class="h-full w-full object-cover">
            </div>
            <h1 class="text-sm sm:text-base font-black tracking-wider text-slate-900 uppercase truncate">Avira Showcase</h1>
        </div>
        <a href="/" class="text-[11px] bg-slate-900 text-white font-bold py-2 px-3.5 sm:px-4 rounded-xl hover:bg-slate-800 transition-all shadow-sm uppercase tracking-wider flex-shrink-0 ml-2">Home</a>
    </header>

    <!-- 🛒 MAIN WORKSPACE -->
    <main class="flex-grow max-w-7xl mx-auto w-full px-4 py-6 sm:py-8 relative z-10 box-border">
        
        <!-- HEADER SEARCH CONTROLS -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 sm:gap-5 mb-6 sm:mb-8">
            <div>
                <h2 class="text-lg sm:text-xl font-black uppercase tracking-tight text-slate-800 border-l-4 border-emerald-500 pl-2.5">Our Products</h2>
                <p class="text-slate-400 text-[10px] sm:text-[11px] mt-0.5 font-medium">Click on any product to view its specialized benefits and usage.</p>
            </div>
            
            <!-- ⚡ SLEEK LIVE SEARCH BAR -->
            <div class="relative w-full sm:max-w-xs">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-slate-400 text-xs">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="productSearch" onkeyup="searchProducts()" placeholder="Search items..." 
                    class="w-full pl-9 pr-4 py-2 bg-white/80 backdrop-blur-md border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none focus:border-emerald-500 focus:bg-white transition-all shadow-sm">
            </div>
        </div>
        
        <!-- 📦 FIXED GRID: grid-cols-2 (Mobile) | sm:3 | md:4 | lg:5 | xl:6 -->
        <div id="productGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3 sm:gap-4">
            <% if(products.length === 0) { %>
                <div id="noProductsMsg" class="text-xs text-slate-400 col-span-full text-center py-16 font-bold">
                    <i class="fa-solid fa-box-open text-2xl text-slate-300 block mb-2"></i> No products active yet.
                </div>
            <% } else { %>
                <div id="noProductsMsg" class="hidden text-xs text-slate-400 col-span-full text-center py-16 font-bold">
                    <i class="fa-solid fa-magnifying-glass-minus text-2xl text-slate-300 block mb-2"></i> Product not found!
                </div>
            <% } %>

            <% products.forEach(product => { %>
                <!-- COMPACT STYLISH CARD -->
                <a href="/products/<%= product.id %>" class="product-card premium-product-card p-2.5 sm:p-3 rounded-2xl flex flex-col justify-between group" data-name="<%= product.name.toUpperCase() %>">
                    
                    <div class="w-full">
                        <!-- IMAGE CONTAINER -->
                        <div class="w-full aspect-square bg-slate-50/50 rounded-xl overflow-hidden mb-2 sm:mb-2.5 flex items-center justify-center relative border border-slate-100/50 p-2">
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="object-contain w-full h-full group-hover:scale-105 transition-transform duration-500">
                            <!-- Mini PV Badge -->
                            <span class="absolute top-1.5 right-1.5 sm:top-2 sm:right-2 bg-emerald-500 text-slate-950 font-black px-1.5 sm:px-2 py-0.5 rounded-md sm:rounded-lg text-[8px] sm:text-[9px] shadow-sm tracking-wide">
                                <%= product.pv %> PV
                            </span>
                        </div>
                        
                        <!-- Product Title -->
                        <h3 class="font-bold text-[10px] sm:text-[11px] text-slate-800 group-hover:text-emerald-600 transition-colors line-clamp-2 leading-tight min-h-[28px] sm:min-h-[32px]">
                            <%= product.name %>
                        </h3>
                    </div>
                    
                    <!-- Card Footer Pricing Details -->
                    <div class="mt-2 sm:mt-2.5 pt-1.5 sm:pt-2 border-t border-slate-100/70 flex items-center justify-between">
                        <span class="text-[8px] sm:text-[9px] font-black uppercase text-slate-400 tracking-wider">Price</span>
                        <span class="text-xs sm:text-sm font-black text-slate-900">₹<%= parseFloat(product.amount).toLocaleString('en-IN') %></span>
                    </div>

                </a>
            <% }) %>
        </div>
    </main>

    <!-- Client-side Fast Filter Engine -->
    <script>
        function searchProducts() {
            const input = document.getElementById('productSearch').value.toUpperCase().trim();
            const cards = document.getElementsByClassName('product-card');
            const noMsg = document.getElementById('noProductsMsg');
            let visibleCount = 0;

            for (let i = 0; i < cards.length; i++) {
                const productName = cards[i].getAttribute('data-name');
                if (productName.includes(input)) {
                    cards[i].style.display = "";
                    visibleCount++;
                } else {
                    cards[i].style.display = "none";
                }
            }

            if (noMsg) {
                if (visibleCount === 0) noMsg.classList.remove('hidden');
                else noMsg.classList.add('hidden');
            }
        }
    </script>

    <!-- Footer Shield Bar -->
    <footer class="bg-white/50 backdrop-blur-md border-t border-slate-200/50 py-3.5 text-center text-[10px] font-semibold text-slate-400 relative z-10 w-full overflow-hidden">
        &copy; 2026 Avira Lifecare Workspace. V1.1 UI Optimized Release.
    </footer>

</body>
</html>

<!DOCTYPE html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Query Support Center - Avira Lifecare</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* 🌌 OVERFLOW SAFE GLASS EFFECTS */
        html, body {
            max-width: 100vw !important;
            overflow-x: hidden !important;
            position: relative;
        }

        .premium-card { 
            background: rgba(255, 255, 255, 0.85); 
            backdrop-filter: blur(16px); 
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6); 
        }

        /* ✨ STRICT OVERFLOW BOUNDED ANIMATED BLOBS */
        .animated-blob {
            filter: blur(80px);
            opacity: 0.35;
            animation: floatBlob 14s infinite alternate ease-in-out;
            will-change: transform;
        }
        @keyframes floatBlob {
            0% { transform: translate(0px, 0px) scale(1); }
            100% { transform: translate(20px, 30px) scale(1.05); }
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col justify-between font-sans antialiased text-slate-800 relative w-full overflow-x-hidden">

    <!-- 🔮 STRICT BOUNDED BACKGROUND ANIMATED SHAPES -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute -top-10 -left-10 w-72 h-72 sm:w-96 sm:h-96 bg-emerald-300/20 rounded-full animated-blob"></div>
        <div class="absolute -bottom-10 -right-10 w-72 h-72 sm:w-96 sm:h-96 bg-blue-300/20 rounded-full animated-blob" style="animation-delay: -5s;"></div>
    </div>

    <!-- 🌐 NAVIGATION HEADER -->
    <header class="bg-white/70 backdrop-blur-md border-b border-slate-100 px-4 sm:px-6 py-3.5 sticky top-0 z-50 shadow-sm w-full">
        <div class="max-w-3xl mx-auto flex justify-between items-center w-full">
            <div class="flex items-center gap-2.5 sm:gap-3 min-w-0">
                <div class="h-9 w-9 rounded-xl overflow-hidden bg-white flex items-center justify-center shadow-md border border-slate-100 flex-shrink-0">
                    <img src="/images/logo.jpg" alt="Avira Logo" class="h-full w-full object-cover">
                </div>
                <div class="truncate">
                    <span class="text-xs sm:text-sm font-black text-slate-900 block truncate">AVIRA LIFECARE</span>
                    <span class="text-[8px] sm:text-[9px] font-bold text-emerald-600 uppercase tracking-widest block -mt-0.5">Query Center</span>
                </div>
            </div>
            <a href="/" class="inline-flex items-center gap-1.5 bg-slate-900 hover:bg-slate-950 text-white text-[10px] font-black px-3.5 py-1.5 rounded-xl uppercase shadow-md transition-all cursor-pointer flex-shrink-0 ml-2">
                <i class="fa-solid fa-house text-[9px]"></i> <span class="hidden sm:inline">Home</span>
            </a>
        </div>
    </header>

    <!-- 📦 MAIN CONTAINER -->
    <main class="flex-grow w-full max-w-2xl mx-auto px-4 py-6 sm:py-8 space-y-6 relative z-10 box-border">
        
        <!-- MEMBER AUTH ID FORM -->
        <div id="authSection" class="premium-card p-5 sm:p-8 rounded-2xl shadow-xl shadow-slate-200/50 text-center space-y-4">
            <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black bg-amber-50 text-amber-700 border border-amber-100 uppercase tracking-wider shadow-sm">
                <i class="fa-solid fa-lock"></i> Secure Gateway
            </div>
            <h2 class="text-lg sm:text-2xl font-black text-slate-950 uppercase">Open Your Support Desk</h2>
            <p class="text-slate-400 text-[11px] sm:text-xs max-w-sm mx-auto leading-relaxed">Enter your unique Avira Member ID to view past ticket history or lodge a new complaint.</p>
            <form id="queryAuthForm" class="flex flex-col sm:flex-row gap-2 max-w-md mx-auto pt-2">
                <input type="text" id="memberIdInput" placeholder="ENTER YOUR MEMBER ID" required class="flex-grow px-4 py-2.5 bg-white/60 border border-slate-200 rounded-xl text-xs font-bold tracking-wider focus:outline-none uppercase text-slate-800">
                <button type="submit" class="bg-slate-900 hover:bg-slate-950 text-white font-black text-xs px-6 py-2.5 rounded-xl uppercase cursor-pointer shadow-md transition-all">Access Desk</button>
            </form>
        </div>

        <!-- MAIN DASHBOARD CONTENT AREA -->
        <div id="dashboardSection" class="hidden space-y-6">
            
            <!-- BUTTON HEADER FOR ADD NEW -->
            <div class="premium-card p-4 rounded-xl flex justify-between items-center shadow-sm">
                <div>
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-wider block">Logged in as:</span>
                    <span id="activeMemberBadge" class="text-xs font-mono font-black text-emerald-600 uppercase">AV12345</span>
                </div>
                <button onclick="toggleForm()" class="bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white text-[10px] sm:text-[11px] font-black px-3.5 py-2 sm:px-4 rounded-xl uppercase tracking-wide cursor-pointer shadow-md transition-all">
                    <i class="fa-solid fa-plus mr-1"></i> Add New Query
                </button>
            </div>

            <!-- LODGE COMPLAINT FORM BOX -->
            <div id="newQueryFormContainer" class="hidden premium-card p-5 sm:p-6 rounded-2xl shadow-lg bg-white/95 space-y-4">
                <h3 class="text-xs sm:text-sm font-black text-slate-900 uppercase border-b pb-2 flex items-center gap-1.5"><i class="fa-solid fa-pen-to-square text-emerald-500"></i> Lodge New Support Ticket</h3>
                <form id="newTicketForm" class="space-y-4">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-wide block mb-1">Subject</label>
                        <input type="text" id="formSubject" placeholder="e.g., Payout Issue, Product Damage" required class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-xs font-bold focus:outline-none">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-wide block mb-1">Description / Ticket Details</label>
                        <textarea id="formDescription" rows="4" placeholder="Write your concern or problem in detail here..." required class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-xs font-medium focus:outline-none"></textarea>
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-wide block mb-1">Contact Number</label>
                        <input type="tel" id="formContactNo" placeholder="Enter 10 Digit Mobile Number" required class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-xs font-bold focus:outline-none">
                    </div>
                    <div class="flex justify-end gap-2 pt-2">
                        <button type="button" onclick="toggleForm()" class="bg-slate-100 hover:bg-slate-200 text-slate-600 text-xs font-bold px-4 py-2 rounded-xl cursor-pointer">Cancel</button>
                        <button type="submit" class="bg-slate-900 hover:bg-slate-950 text-white text-xs font-black px-6 py-2 rounded-xl uppercase cursor-pointer shadow-md">Submit Ticket</button>
                    </div>
                </form>
            </div>

            <!-- TICKET HISTORY VIEW LIST -->
            <div class="space-y-4">
                <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1"><i class="fa-solid fa-clock-history text-emerald-500 mr-1"></i> Past Query History</h3>
                <div id="historyList" class="space-y-3"></div>
            </div>

        </div>

    </main>

    <!-- 🌐 FOOTER -->
    <footer class="bg-white/60 backdrop-blur-md border-t border-slate-100 py-4 text-center text-[10px] text-slate-400 px-4 relative z-10 w-full overflow-hidden">
        &copy; 2026 Avira Lifecare. Secure Query Manager System.
    </footer>

    <script>
        let loggedMemberId = '';

        document.getElementById('queryAuthForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const mId = document.getElementById('memberIdInput').value.trim().toUpperCase();
            if(!mId) return;

            loggedMemberId = mId;
            document.getElementById('activeMemberBadge').innerText = mId;
            document.getElementById('authSection').classList.add('hidden');
            document.getElementById('dashboardSection').classList.remove('hidden');

            fetchHistory();
        });

        function toggleForm() {
            const container = document.getElementById('newQueryFormContainer');
            container.classList.toggle('hidden');
        }

        async function fetchHistory() {
            try {
                const response = await fetch(`/api/queries/history?memberId=${encodeURIComponent(loggedMemberId)}`);
                const data = await response.json();
                const list = document.getElementById('historyList');
                list.innerHTML = '';

                if(data && data.length > 0) {
                    data.forEach(ticket => {
                        let statusColor = 'bg-amber-50 text-amber-700 border-amber-200';
                        if(ticket.status === 'ACCEPTED') statusColor = 'bg-blue-50 text-blue-700 border-blue-200';
                        if(ticket.status === 'SOLVED') statusColor = 'bg-emerald-50 text-emerald-700 border-emerald-200';

                        list.innerHTML += `
                            <div class="premium-card p-4 sm:p-5 rounded-2xl bg-white shadow-sm border border-slate-100/70 space-y-3">
                                <div class="flex justify-between items-start gap-3">
                                    <div>
                                        <span class="text-[9px] font-black text-slate-400 uppercase tracking-wide block">Ticket ID: #${ticket.id}</span>
                                        <h4 class="text-xs font-black text-slate-900 mt-0.5 uppercase">${ticket.subject}</h4>
                                    </div>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[9px] sm:text-[10px] font-black border uppercase tracking-wide flex-shrink-0 ${statusColor}">${ticket.status}</span>
                                </div>
                                <p class="text-xs text-slate-600 leading-relaxed font-medium bg-slate-50/50 p-3 rounded-xl border border-slate-100/40 break-words">${ticket.description}</p>
                                <div class="flex justify-between items-center text-[10px] text-slate-400 font-bold border-t pt-2 border-slate-100 flex-wrap gap-1">
                                    <span><i class="fa-solid fa-phone text-slate-300 mr-0.5"></i> Call: ${ticket.contact_no}</span>
                                    <span><i class="fa-solid fa-calendar text-slate-300 mr-0.5"></i> ${new Date(ticket.created_at).toLocaleString()}</span>
                                </div>
                            </div>
                        `;
                    });
                } else {
                    list.innerHTML = `
                        <div class="premium-card p-8 text-center rounded-2xl bg-white shadow-sm">
                            <i class="fa-solid fa-face-smile text-3xl block mb-2 text-slate-200"></i>
                            <p class="text-[11px] text-slate-400 font-bold uppercase tracking-wider">No tickets raised yet!</p>
                        </div>`;
                }
            } catch (err) { console.error(err); }
        }

        document.getElementById('newTicketForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const subject = document.getElementById('formSubject').value.trim();
            const description = document.getElementById('formDescription').value.trim();
            const contactNo = document.getElementById('formContactNo').value.trim();

            try {
                const res = await fetch('/api/queries/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ memberId: loggedMemberId, subject, description, contactNo })
                });
                const result = await res.json();
                if(result.success) {
                    alert(result.msg);
                    document.getElementById('newTicketForm').reset();
                    toggleForm();
                    fetchHistory();
                } else { alert(result.msg); }
            } catch(err) { console.error(err); }
        });
    </script>
</body>
</html>
